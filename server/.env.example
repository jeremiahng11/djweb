# Postgres connection string (Coolify: use the internal connection URL of your Postgres service)
DATABASE_URL=postgres://doodle:doodle@localhost:5432/doodle

# Port the API listens on
PORT=3001

# Serve the API under a sub-path on the SAME domain as the game (e.g. djweb.jeremiah.sg/djapi).
# Set this to the path ONLY if Coolify forwards the prefix without stripping it (we test with curl).
# Leave unset if the proxy strips the prefix, or if the API has its own domain.
# BASE_PATH=/djapi

# CORS allowed origins. NOT needed when the API is same-origin (under the game's domain).
# Only set this if the API is on a different domain than the game.
# CORS_ORIGIN=https://djweb.jeremiah.sg
